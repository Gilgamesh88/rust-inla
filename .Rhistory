library(INLA)
library(jsonlite)
dir.create("tests/fixtures", showWarnings = FALSE, recursive = TRUE)
# ── Fixture 1: IID Gaussiano ──────────────────────────────────────────────────
set.seed(42)
n <- 5000  # grande desde el inicio para medir performance real
y <- rnorm(n, mean = 2.0, sd = 1.5)
m_iid <- inla(
y ~ 1 + f(idx, model = "iid"),
data = list(y = y, idx = 1:n),
family = "gaussian",
control.compute = list(config = TRUE)
)
write_json(list(
y = y, idx = 1:n, family = "gaussian",
theta_opt = m_iid$mode$theta,
log_mlik  = m_iid$mlik[1, 1],
mean_x    = m_iid$summary.random$idx$mean,
sd_x      = m_iid$summary.random$idx$sd,
mean_intercept = m_iid$summary.fixed["(Intercept)", "mean"]
), "tests/fixtures/iid_gaussian.json", digits = 15)
cat("✓ iid_gaussian.json\n")
# ── Fixture 2: RW1 Poisson ────────────────────────────────────────────────────
set.seed(42)
n_rw <- 500  # suficiente para medir tiempo de Cholesky
t_idx <- 1:n_rw
log_mu <- cumsum(rnorm(n_rw, 0, 0.3))
y_pois <- rpois(n_rw, exp(log_mu + 0.5))
m_rw1 <- inla(
y ~ 1 + f(t, model = "rw1"),
data = list(y = y_pois, t = t_idx),
family = "poisson",
control.compute = list(config = TRUE)
)
write_json(list(
y = y_pois, t = t_idx, family = "poisson",
theta_opt = m_rw1$mode$theta,
log_mlik  = m_rw1$mlik[1, 1],
mean_x    = m_rw1$summary.random$t$mean,
sd_x      = m_rw1$summary.random$t$sd,
mean_intercept = m_rw1$summary.fixed["(Intercept)", "mean"]
), "tests/fixtures/rw1_poisson.json", digits = 15)
cat("✓ rw1_poisson.json\n")
# ── Fixture 3: AR1 Gamma ──────────────────────────────────────────────────────
set.seed(42)
n_ar <- 400
rho_true <- 0.7
x_ar <- numeric(n_ar)
x_ar[1] <- rnorm(1, 0, 1 / sqrt(1 - rho_true^2))
for (i in 2:n_ar) x_ar[i] <- rho_true * x_ar[i-1] + rnorm(1, 0, 0.5)
y_gam <- rgamma(n_ar, shape = 2, rate = 2 * exp(-x_ar))
m_ar1 <- inla(
y ~ 1 + f(t, model = "ar1"),
data = list(y = y_gam, t = 1:n_ar),
family = "gamma",
control.compute = list(config = TRUE)
)
write_json(list(
y = y_gam, t = 1:n_ar, family = "gamma",
theta_opt = m_ar1$mode$theta,
log_mlik  = m_ar1$mlik[1, 1],
mean_x    = m_ar1$summary.random$t$mean,
sd_x      = m_ar1$summary.random$t$sd
), "tests/fixtures/ar1_gamma.json", digits = 15)
cat("✓ ar1_gamma.json\n")
# ── Fixture 4: Cholesky directo ───────────────────────────────────────────────
# n=10000 para medir performance real del solver
n_q <- 10000
# RW1 tridiagonal — D^T D
i_idx <- c(1:n_q, 1:(n_q-1), 2:n_q)
j_idx <- c(1:n_q, 2:n_q, 1:(n_q-1))
v_diag <- c(rep(2, n_q-2), 1, 1)  # bordes tienen 1 vecino
v_off   <- rep(-1, n_q-1)
vals    <- c(v_diag, v_off, v_off)
# Pequeña perturbación diagonal para PD estricta
eps <- 1e-6
i_idx <- c(i_idx, 1:n_q)
j_idx <- c(j_idx, 1:n_q)
vals  <- c(vals, rep(eps, n_q))
Q_sparse <- Matrix::sparseMatrix(i=i_idx, j=j_idx, x=vals, dims=c(n_q,n_q))
rhs <- rnorm(n_q)
# Referencia: Cholesky de Matrix
ch <- Matrix::Cholesky(Q_sparse, perm=TRUE, LDL=FALSE)
# ── Fixture 4: Cholesky directo ───────────────────────────────────────────────
n_q <- 10000
# RW1 tridiagonal D^T D — construir directamente sin duplicados
# Diagonal: [1, 2, 2, ..., 2, 1] + eps para PD estricta
eps <- 1e-6
diag_vals <- c(1 + eps, rep(2 + eps, n_q - 2), 1 + eps)
off_vals  <- rep(-1, n_q - 1)
# Triplets: diagonal + subdiagonal + superdiagonal
i_idx <- c(1:n_q,       1:(n_q-1), 2:n_q)
j_idx <- c(1:n_q,       2:n_q,     1:(n_q-1))
vals  <- c(diag_vals,   off_vals,  off_vals)
Q_sparse <- Matrix::sparseMatrix(
i = i_idx, j = j_idx, x = vals,
dims = c(n_q, n_q), symmetric = FALSE
)
rhs <- rnorm(n_q)
# Cholesky — usar chol() estándar sobre la sparse matrix
ch  <- Matrix::chol(Q_sparse)          # devuelve R tal que R^T R = Q
sol <- Matrix::solve(ch, Matrix::solve(Matrix::t(ch), rhs))
log_det <- 2 * sum(log(Matrix::diag(ch)))
# Guardar triplets upper triangle únicamente
Q_upper <- Matrix::triu(Q_sparse)
Q_upper_coo <- Matrix::summary(Q_upper)   # data.frame con i, j, x
write_json(list(
n       = n_q,
rows    = as.integer(Q_upper_coo$i - 1L),  # base-0 para Rust
cols    = as.integer(Q_upper_coo$j - 1L),
vals    = Q_upper_coo$x,
rhs     = rhs,
sol     = sol,
log_det = log_det
), "tests/fixtures/cholesky_rw1.json", digits = 15)
cat("✓ cholesky_rw1.json (n=10000)\n")
cat("\n── Tolerancias de validación ──\n")
cat("log_mlik:  atol = 1e-4\n")
cat("mean_x:    atol = 1e-3\n")
cat("log_det:   atol = 1e-8\n")
cat("sol:       atol = 1e-8\n")
devtools::load_all()
# generate_fixtures.R
#
# Generates JSON fixtures for rust-inla integration tests.
# Run once with R-INLA installed, then commit the JSON files.
#
# Usage:
#   Rscript generate_fixtures.R
#
# Output: tests/fixtures/*.json
#
# Install R-INLA if needed:
#   install.packages("INLA", repos = c(INLA = "https://inla.r-inla-download.org/R/stable"))
library(INLA)
library(jsonlite)
dir.create("tests/fixtures", recursive = TRUE, showWarnings = FALSE)
set.seed(42)
# ── Helper ────────────────────────────────────────────────────────────────────
save_fixture <- function(obj, name) {
path <- file.path("tests/fixtures", paste0(name, ".json"))
write(toJSON(obj, auto_unbox = TRUE, digits = 10), path)
cat("Saved:", path, "\n")
}
# ── Fixture 1: iid Gaussian, n=200 ───────────────────────────────────────────
# R-INLA: inla(y ~ f(idx, model="iid"), family="gaussian")
# Used to validate: intercept, latent means, log_mlik
n <- 200
true_tau_x   <- 4.0     # precision of random effect
true_tau_obs <- 2.0     # observation precision
true_beta0   <- 1.5
x  <- rnorm(n, 0, 1 / sqrt(true_tau_x))
y  <- true_beta0 + x + rnorm(n, 0, 1 / sqrt(true_tau_obs))
idx <- 1:n
r <- inla(
y ~ 1 + f(idx, model = "iid"),
family = "gaussian",
data   = data.frame(y = y, idx = idx),
control.compute = list(mlik = TRUE),
control.predictor = list(compute = TRUE)
)
save_fixture(list(
name        = "iid_gaussian_n200",
n           = n,
y           = as.numeric(y),
intercept_mean = r$summary.fixed["(Intercept)", "mean"],
intercept_sd   = r$summary.fixed["(Intercept)", "sd"],
latent_means   = as.numeric(r$summary.random$idx[, "mean"]),
latent_sds     = as.numeric(r$summary.random$idx[, "sd"]),
log_mlik       = as.numeric(r$mlik[1]),
theta_opt      = as.numeric(r$mode$theta)
), "iid_gaussian_n200")
# ── Fixture 2: rw1 Poisson, n=100 ────────────────────────────────────────────
# R-INLA: inla(y ~ f(t, model="rw1"), family="poisson")
# Used to validate: Poisson likelihood, rw1 precision, log_mlik
n  <- 100
t  <- 1:n
f  <- cumsum(rnorm(n, 0, 0.3))   # smooth latent signal
lambda <- exp(f)
y  <- rpois(n, lambda)
r2 <- inla(
y ~ f(t, model = "rw1"),
family = "poisson",
data   = data.frame(y = y, t = t),
control.compute = list(mlik = TRUE)
)
save_fixture(list(
name         = "rw1_poisson_n100",
n            = n,
y            = as.numeric(y),
latent_means = as.numeric(r2$summary.random$t[, "mean"]),
latent_sds   = as.numeric(r2$summary.random$t[, "sd"]),
log_mlik     = as.numeric(r2$mlik[1]),
theta_opt    = as.numeric(r2$mode$theta)
), "rw1_poisson_n100")
# ── Fixture 3: ar1 Gamma, n=100 ──────────────────────────────────────────────
# R-INLA: inla(y ~ f(t, model="ar1"), family="gamma")
# Used to validate: Gamma likelihood, AR1 precision + rho
n   <- 100
rho <- 0.8
tau <- 3.0
x   <- numeric(n)
x[1] <- rnorm(1, 0, 1 / sqrt(tau * (1 - rho^2)))
for (i in 2:n) x[i] <- rho * x[i-1] + rnorm(1, 0, 1 / sqrt(tau))
mu  <- exp(x)
phi <- 2.0
y   <- rgamma(n, shape = phi, rate = phi / mu)
r3 <- inla(
y ~ f(t, model = "ar1"),
family = "gamma",
data   = data.frame(y = y, t = 1:n),
control.compute = list(mlik = TRUE)
)
save_fixture(list(
name         = "ar1_gamma_n100",
n            = n,
y            = as.numeric(y),
latent_means = as.numeric(r3$summary.random$t[, "mean"]),
latent_sds   = as.numeric(r3$summary.random$t[, "sd"]),
log_mlik     = as.numeric(r3$mlik[1]),
theta_opt    = as.numeric(r3$mode$theta)
), "ar1_gamma_n100")
# ── Fixture 4: cholesky rw1 (solver validation) ───────────────────────────────
# Pure linear algebra: log|Q_rw1| and solve for known rhs.
# No R-INLA call needed — uses analytical values.
n_chol <- 50
tau_chol <- 2.5
# Build Q_rw1 as dense matrix
Q <- matrix(0, n_chol, n_chol)
for (i in 1:n_chol) {
if (i == 1 || i == n_chol) Q[i, i] <- tau_chol * 1
else                         Q[i, i] <- tau_chol * 2
if (i > 1)       Q[i, i-1] <- -tau_chol
if (i < n_chol)  Q[i, i+1] <- -tau_chol
}
Q_pd <- Q + diag(1e-4, n_chol)   # small diagonal to make PD
L       <- chol(Q_pd)
log_det <- 2 * sum(log(diag(L)))
rhs     <- rnorm(n_chol)
x_sol   <- backsolve(L, forwardsolve(t(L), rhs))
save_fixture(list(
name    = "cholesky_rw1",
n       = n_chol,
tau     = tau_chol,
log_det = log_det,
rhs     = as.numeric(rhs),
x_sol   = as.numeric(x_sol)
), "cholesky_rw1")
cat("\nAll fixtures generated in tests/fixtures/\n")
cat("Commit with: git add tests/fixtures/ && git commit -m 'chore: add R-INLA validation fixtures'\n")
